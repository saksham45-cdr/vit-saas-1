# ═══════════════════════════════════════════════════════════════
# HotelIQ backend — environment template. Placeholders ONLY.
# Copy to .env (never commit .env) or set in Vercel project settings.
# ═══════════════════════════════════════════════════════════════

# NVIDIA LLM keys — two SEPARATE keys, two separate responsibilities
NVIDIA_API_KEY_1=            # Query Intelligence Engine (search-time JSON parsing)
NVIDIA_API_KEY_2=            # Hotel Summary Generator (ingestion-time only)

# DataForSEO (Google Organic API — ingestion-time only)
DATAFORSEO_USERNAME=
DATAFORSEO_PASSWORD=

# Supabase (service role key = server-side ONLY, never expose to a client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel
VERCEL_OIDC_TOKEN=

# Client hotel database
CLIENT_HOTEL_DATABASE_KEY=
CLIENT_HOTEL_DATABASE_URL=   # e.g. https://client-hotels.example.com/api/hotels

# Internal endpoints (monitoring / ingestion triggers) — generate a long random string
INTERNAL_API_SECRET=
# Vercel cron auth (set the same value in the Vercel dashboard)
CRON_SECRET=

# ── Optional tunables (defaults shown) ─────────────────────────
# NVIDIA_MODEL_QUERY=meta/llama-3.1-70b-instruct
# NVIDIA_MODEL_SUMMARY=meta/llama-3.1-70b-instruct
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_KEY1_DAILY_REQUEST_QUOTA=5000
# NVIDIA_KEY2_DAILY_REQUEST_QUOTA=2000
# DATAFORSEO_HARD_STOP_USD=20
# DATAFORSEO_WARN_USD=16
# DATAFORSEO_COST_PER_TASK_USD=0.002
# SEARCH_CACHE_TTL_MS=60000
# SEARCH_RESULT_LIMIT=12
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=30
# INGEST_BATCH_SIZE=10
