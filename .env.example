SUPABASE_URL=
SUPABASE_SERVICE_KEY=
GROQ_API_KEY=

# Primary search provider — Serper.dev (free tier: 2,500/month)
# Warning at 2,000 | Hard stop at 2,400
SERPER_API_KEY=

# Optional: seed baseline for Serper calls made before DB tracking was active
SERPER_USAGE_OFFSET=0

# Fallback search provider — SerpAPI (used only when Serper quota is exhausted)
SERP_API_KEY=
PLAYWRIGHT_HEADLESS=true

# Optional: override VIT hotels API base URL (must use https://)
VIT_HOTELS_API_URL=https://api.vit.travel/hotels/index.php

# Optional: set to protect internal pipeline routes with x-api-key header
INTERNAL_API_KEY=

# Safety guard — runAllHotels will throw unless this is explicitly set to true
# WARNING: enabling this consumes ~3 SerpAPI calls per uncached hotel (5000 hotels = 15,000 calls)
ALLOW_BULK_RUN=false

# Seed baseline for calls made before serp_usage DB tracking was active.
# Check your SerpAPI dashboard and set this to the number of calls already used this month.
SERP_USAGE_OFFSET=0
